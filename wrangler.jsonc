{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eldendle",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "main": "src/worker.js",
  "kv_namespaces": [
    {
      "binding": "ELDEN_STATS",
      "id": "197834760c42dac97b9_placeholder"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}